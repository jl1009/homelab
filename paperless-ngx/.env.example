# Network and Deployment Environment
DOCKER_NETWORK=paperless_shared_net
TZ=America/Los_Angeles
PUID=1000
PGID=1000
PORT=8000

# Directory Paths
REDIS_DATA_DIR=/path/to/redis_data
DB_DATA_DIR=/path/to/pg_data
DATA_DIR=/path/to/data
MEDIA_DIR=/path/to/media
CONSUME_DIR=/path/to/consume
EXPORT_DIR=/path/to/export

# Database Settings
DB_NAME=paperless
DB_USER=paperless
DB_PASSWORD=secure_password_here

# Paperless Core Settings
PAPERLESS_SECRET_KEY=change_this_to_a_random_long_string
PAPERLESS_URL=http://your-homelab-ip:8000

# Azure OCR Settings
# PAPERLESS_REMOTE_OCR_ENGINE=azureai
# PAPERLESS_AZURE_OCR_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
# PAPERLESS_AZURE_OCR_KEY=your_azure_api_key_here


